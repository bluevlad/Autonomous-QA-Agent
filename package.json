{
  "name": "autonomous-qa-agent",
  "version": "1.0.0",
  "description": "Autonomous QA testing hub for multiple web projects",
  "type": "module",
  "scripts": {
    "test:all": "playwright test",
    "test:hopenvision": "playwright test --project=hopenvision",
    "test:allergyinsight": "playwright test --project=allergyinsight",
    "test:edufit": "playwright test --project=edufit",
    "test:newsletterplatform": "playwright test --project=newsletterplatform",
    "test:unmong-main": "playwright test --project=unmong-main",
    "test:standup": "playwright test --project=standup",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "issues:create": "node scripts/create-issues.js",
    "project:add": "node scripts/add-project.js",
    "scheduler:start": "tsx scheduler/index.ts",
    "scheduler:run": "tsx scheduler/index.ts --run",
    "scheduler:register": "scheduler\\scripts\\register-task.bat",
    "scheduler:unregister": "scheduler\\scripts\\unregister-task.bat",
    "migrate:logs": "tsx scheduler/migrate-logs.ts"
  },
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "automation",
    "e2e"
  ],
  "author": "bluevlad",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.3.1",
    "playwright-slack-report": "^1.1.109",
    "typescript": "^5.9.0",
    "node-cron": "^3.0.3",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0"
  }
}
