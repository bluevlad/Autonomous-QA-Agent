# ============================================
# Autonomous QA Agent - 환경 변수 설정
# ============================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env

# --- Slack 연동 ---
# Slack App > Incoming Webhooks에서 생성한 Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../XXX

# (선택) Slack Bot Token - 2단계 다중 채널 전송용
# SLACK_BOT_TOKEN=xoxb-...

# --- 프로젝트별 URL (기본값: localhost) ---
# 운영서버 사용 시 아래 값을 설정하세요.
# 미설정 프로젝트는 localhost 기본값 → Health Check 실패 시 자동 스킵
# UNMONG_MAIN_URL=http://www.unmong.com
# HOPENVISION_URL=http://www.unmong.com:4060
# HOPENVISION_API_URL=http://172.30.1.72:9050
# ALLERGYINSIGHT_URL=http://172.30.1.72:4040
# ALLERGYINSIGHT_API_URL=http://172.30.1.72:9040
# EDUFIT_URL=http://172.30.1.72:4070
# EDUFIT_API_URL=http://172.30.1.72:9070
# NEWSLETTERPLATFORM_URL=http://172.30.1.72:4055
# STANDUP_API_URL=http://172.30.1.72:9060

# --- 스케줄러 설정 ---
# Cron 표현식 (기본: 매일 22:00)
# SCHEDULER_CRON=0 22 * * *
# Health Check 타임아웃 (ms)
# HEALTH_CHECK_TIMEOUT=10000
# 테스트 타임아웃 (ms)
# TEST_TIMEOUT=300000
# 로그 저장 디렉토리
# SCHEDULER_LOG_DIR=./scheduler/logs

# --- QA Dashboard ---
# Dashboard API URL (macOS OrbStack)
# DASHBOARD_API_URL=http://172.30.1.72:9095
# Dashboard API Key (backend와 일치해야 함)
# DASHBOARD_API_KEY=qa-agent-secret-key

# --- 실행 환경 ---
# NODE_ENV=local
# CI=false
