# ============================================
# Autonomous QA Agent - 환경 변수 설정
# ============================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env

# --- Slack 연동 ---
# Slack App > Incoming Webhooks에서 생성한 Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../XXX

# (선택) Slack Bot Token - 2단계 다중 채널 전송용
# SLACK_BOT_TOKEN=xoxb-...

# --- 프로젝트별 URL (기본값: localhost) ---
# HOPENVISION_URL=http://localhost:4060
# HOPENVISION_API_URL=http://localhost:9050
# TEACHERHUB_URL=http://localhost:4010
# TEACHERHUB_API_URL=http://localhost:8081
# ALLERGYINSIGHT_URL=http://localhost:4040
# ALLERGYINSIGHT_API_URL=http://localhost:9040
# HEALTHPULSE_URL=http://localhost:4030
# ALLERGYNEWSLETTER_URL=http://localhost:4050
# ACADEMYINSIGHT_URL=http://localhost:4020
# ACADEMYINSIGHT_API_URL=http://localhost:8082
# NEWSLETTERPLATFORM_URL=http://localhost:4055
# UNMONG_MAIN_URL=http://localhost:80
# STANDUP_API_URL=http://localhost:9060

# --- 스케줄러 설정 ---
# Cron 표현식 (기본: 매일 22:00)
# SCHEDULER_CRON=0 22 * * *
# Health Check 타임아웃 (ms)
# HEALTH_CHECK_TIMEOUT=10000
# 테스트 타임아웃 (ms)
# TEST_TIMEOUT=300000
# 로그 저장 디렉토리
# SCHEDULER_LOG_DIR=./scheduler/logs

# --- 실행 환경 ---
# NODE_ENV=local
# CI=false
